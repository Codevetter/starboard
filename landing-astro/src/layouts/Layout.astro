---
import '@/styles/landing.css';

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

const SITE_URL = 'https://starboard.sarthakagrawal927.workers.dev';
// OG image lives on the Next.js Worker at /opengraph-image (Next file
// convention → dynamic JSX → PNG). The single-Worker overlay keeps that
// route on the OpenNext side, so this URL still resolves.
const OG_IMAGE = `${SITE_URL}/opengraph-image`;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="application-name" content="Starboard" />
    <meta
      name="keywords"
      content="GitHub stars, repository organizer, semantic search, open source discovery"
    />

    <link rel="canonical" href={SITE_URL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={SITE_URL} />
    <meta property="og:site_name" content="Starboard" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={OG_IMAGE} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={OG_IMAGE} />

    {/* ── Fonts ────────────────────────────────────────────────────
       Only Geist (the LCP-h1 face) is on the critical path. Preload
       + media=print swap pattern so the stylesheet never blocks first
       paint; <noscript> fallback covers no-JS clients. Geist Mono is
       loaded as part of the same Google Fonts request because the
       browser dedupes the css2 fetch, but it's not LCP-critical. */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      />
    </noscript>

    {/* Wire the same CSS vars Next.js's next/font sets up, so any
       Tailwind class using --font-geist-sans / --font-geist-mono keeps
       working without a rebuild. */}
    <style is:inline>
      :root {
        --font-geist-sans: 'Geist', system-ui, -apple-system, sans-serif;
        --font-geist-mono: 'Geist Mono', ui-monospace, Menlo, monospace;
      }
      html.dark { color-scheme: dark; }
      body { margin: 0; }
    </style>
  </head>
  <body class="antialiased">
    <slot />
  </body>
</html>
